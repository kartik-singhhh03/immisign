# ==========================================
# IMMISIGN ENVIRONMENT VARIABLES (PLACEHOLDERS ONLY)
# Copy to .env.local for local dev. Set in Vercel for production.
# Never commit real secrets.
# ==========================================

# 1. APPLICATION
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# 2. SUPABASE (Required for production)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional: direct Postgres URL for seed/migration scripts only (never expose to browser)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.your-project-id.supabase.co:5432/postgres"

# 3. SIGNWELL API (Required for agreement e-sign)
SIGNWELL_API_KEY="your_signwell_api_key"
SIGNWELL_WEBHOOK_SECRET="your_signwell_webhook_secret"
SIGNWELL_BASE_URL="https://www.signwell.com/api/v1"

# 4. STRIPE API (Required for billing)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"

# Stripe Plan IDs (match your Stripe Dashboard products)
STRIPE_STARTER_MONTHLY_PRICE_ID="price_starter_test"
STRIPE_STARTER_YEARLY_PRICE_ID="price_starter_yearly_test"
STRIPE_PRO_MONTHLY_PRICE_ID="price_pro_test"
STRIPE_PRO_YEARLY_PRICE_ID="price_pro_yearly_test"
STRIPE_AGENCY_MONTHLY_PRICE_ID="price_agency_test"
STRIPE_AGENCY_YEARLY_PRICE_ID="price_agency_yearly_test"

# 5. RESEND API (Required for transactional email)
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="support@yourdomain.com"
RESEND_WEBHOOK_SECRET="whsec_your_resend_webhook_secret"

# 6. OPTIONAL — E2E / local test scripts only (not used by Next.js runtime)
# E2E_TEST_EMAIL="owner@demoagency.com"
# E2E_TEST_PASSWORD="your-local-seed-password"
# E2E_AGENCY_ID="your-agency-uuid"

# Note: JWT_SECRET and NEXTAUTH_SECRET are not used by this app (Supabase Auth).
