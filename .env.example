# ==========================================
# IMMISIGN ENVIRONMENT VARIABLES (PLACEHOLDERS ONLY)
# Copy to .env.local for local dev. Set in Vercel for production.
# Never commit real secrets.
# ==========================================

# 1. APPLICATION
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# 2. SUPABASE (Required for production)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional: direct Postgres URL for seed/migration scripts only (never expose to browser)
# Required to apply migrations: node scripts/phase11-3-apply-repair-only.mjs
# Prefer direct host (most reliable):
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.your-project-id.supabase.co:5432/postgres"
# Or password only (scripts try direct host first, then pooler):
# SUPABASE_DB_PASSWORD="your-db-password"
# SUPABASE_DB_REGION="ap-southeast-2"

# 3. SIGNWELL API (Required for agreement e-sign)
SIGNWELL_API_KEY="your_signwell_api_key"
# Webhook subscription `id` from GET /api/v1/hooks (node scripts/list-signwell-hooks.mjs)
# HMAC key for event.hash — same subscription as Workspace Callback URL in dashboard
SIGNWELL_WEBHOOK_ID="your_hook_uuid_from_list_hooks_api"
# Optional legacy body HMAC secret (NOT the hook id unless it is a UUID); official verify uses event.hash
SIGNWELL_WEBHOOK_SECRET=""
# Local ngrok only — never enable in production
# SKIP_WEBHOOK_VALIDATION=true
SIGNWELL_BASE_URL="https://www.signwell.com/api/v1"

# Agreement signing provider: native (ImmiSign portal) or signwell (fallback)
# Default: native. Set signwell to use SignWell for agreement dispatch.
SIGNING_PROVIDER="native"

# 4. STRIPE API (Required for billing)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"

# ImmiSign Plan — create in Stripe Dashboard (see docs/STRIPE_MIGRATION_PHASE10.md)
STRIPE_IMMISIGN_BASE_PRICE_ID="price_immisign_base_test"
STRIPE_IMMISIGN_SEAT_PRICE_ID="price_immisign_seat_test"

# 5. RESEND API (Required for transactional email)
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="support@yourdomain.com"
RESEND_WEBHOOK_SECRET="whsec_your_resend_webhook_secret"

# 6. OPTIONAL — E2E / local test scripts only (not used by Next.js runtime)
# E2E_TEST_EMAIL="owner@demoagency.com"
# E2E_TEST_PASSWORD="your-local-seed-password"
# E2E_AGENCY_ID="your-agency-uuid"

# Note: JWT_SECRET and NEXTAUTH_SECRET are not used by this app (Supabase Auth).
